{
  "manifest_version": 3,
  "name": "TinyTasks",
  "description": "A simple task manager Chrome extension.",
  "version": "1.0.0",

  "permissions": [
    "storage"
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  }
}